{
  "name": "website",
  "version": "0.10.0",
  "private": true,
  "scripts": {
    "build": "cross-env NODE_OPTIONS=--no-deprecation next build",
    "dev": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=2048\" next dev",
    "dev:prod": "cross-env NODE_OPTIONS=--no-deprecation rm -rf .next && pnpm build && pnpm start",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "ii": "cross-env NODE_OPTIONS=--no-deprecation pnpm --ignore-workspace install",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation eslint .",
    "lint:fix": "cross-env NODE_OPTIONS=--no-deprecation eslint . --fix",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "reinstall": "cross-env NODE_OPTIONS=--no-deprecation rm -rf node_modules && rm pnpm-lock.yaml && pnpm --ignore-workspace install",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "ci": "payload migrate && pnpm run build",
    "format": "prettier --write src/**/*.{ts,tsx,js,jsx,json,md}",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@faceless-ui/modal": "3.0.0",
    "@faceless-ui/scroll-info": "2.0.0",
    "@payloadcms/db-postgres": "3.82.1",
    "@payloadcms/email-nodemailer": "3.82.1",
    "@payloadcms/next": "3.82.1",
    "@payloadcms/richtext-lexical": "3.82.1",
    "@payloadcms/storage-s3": "^3.82.1",
    "@payloadcms/ui": "^3.82.1",
    "@radix-ui/react-dialog": "^1.1.1",
    "@radix-ui/react-scroll-area": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-toast": "^1.2.2",
    "@tanstack/react-query": "^5.59.16",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "cross-env": "^10.1.0",
    "embla-carousel-react": "^8.1.8",
    "graphql": "^16.8.1",
    "lucide-react": "^0.424.0",
    "next": "16.2.3",
    "nodemailer": "^8.0.5",
    "payload": "3.82.1",
    "pg": "^8.13.0",
    "qs": "^6.15.0",
    "react": "19.2.4",
    "react-cookie": "^8.0.1",
    "react-dom": "19.2.4",
    "sharp": "^0.33.5",
    "streamifier": "^0.1.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.1.0",
    "@eslint/js": "^9.14.0",
    "@tailwindcss/typography": "^0.5.15",
    "@types/node": "^20",
    "@types/nodemailer": "^6.4.16",
    "@types/qs": "^6.15.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/streamifier": "^0.1.2",
    "eslint": "^9.14.0",
    "eslint-config-next": "16.2.3",
    "postcss": "^8",
    "prettier": "^3.3.3",
    "tailwind-merge": "^2.5.4",
    "tailwindcss": "^3.4.1",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5"
  },
  "pnpm": {
    "overrides": {
      "brace-expansion@<1.1.13": "1.1.13",
      "brace-expansion@>=2.0.0 <2.0.3": "2.0.3",
      "brace-expansion@>=5.0.0 <5.0.5": "5.0.5",
      "dompurify": "3.3.3",
      "drizzle-orm": "0.45.2",
      "esbuild@<=0.24.2": "0.25.12",
      "happy-dom": "20.8.9",
      "lodash": "4.18.1",
      "nodemailer": "8.0.5",
      "picomatch@<2.3.2": "2.3.2",
      "picomatch@>=4.0.0 <4.0.4": "4.0.4",
      "yaml@<1.10.3": "1.10.3"
    }
  },
  "type": "module"
}
